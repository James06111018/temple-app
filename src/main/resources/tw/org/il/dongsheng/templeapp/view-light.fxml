<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21">

    <top>
        <VBox>
            <ToolBar style="-fx-background-color: #f0f0f0;">
                <Button styleClass="btn-action" text="新增電腦編號" />
                <Button styleClass="btn-action" text="存檔" />
                <Button styleClass="btn-action" text="刪除" />
                <Button styleClass="btn-action" text="查詢" />
                <Button styleClass="btn-action" text="欄位淨空" />
                <Button styleClass="btn-action" text="總金額" />
                <Separator orientation="VERTICAL" />
                <Button text="上筆" />
                <Button text="下筆" />
                <Button styleClass="btn-highlight" text="全戶點燈" />
                <Button text="管理" />
            </ToolBar>
        </VBox>
    </top>

    <center>
        <HBox spacing="5">
            <padding><Insets bottom="5" left="5" right="5" top="5" /></padding>

            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <TitledPane animated="false" collapsible="false" text="信眾基本資料">
                    <GridPane hgap="8" vgap="5">
                        <columnConstraints>
                            <ColumnConstraints halignment="RIGHT" minWidth="70" />
                            <ColumnConstraints minWidth="120" />
                            <ColumnConstraints halignment="RIGHT" minWidth="60" />
                            <ColumnConstraints minWidth="120" />
                            <ColumnConstraints halignment="RIGHT" minWidth="40" />
                            <ColumnConstraints minWidth="80" />
                        </columnConstraints>

                        <Label text="電腦編號" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="pcIdField" editable="false" style="-fx-background-color: #ffffcc;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="姓名" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <HBox spacing="2" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <TextField fx:id="nameField" HBox.hgrow="ALWAYS" />
                            <Button text="F4" style="-fx-font-size: 10;" />
                        </HBox>

                        <Label text="性別" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                        <ComboBox fx:id="genderBox" prefWidth="80" GridPane.columnIndex="5" GridPane.rowIndex="0" />

                        <Label text="電話" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="縣市別" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <ComboBox fx:id="cityBox" prefWidth="120" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                        <Label text="郵遞區號" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="zipCodeField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="地址" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                        <TextField fx:id="addressField" GridPane.columnIndex="3" GridPane.columnSpan="3" GridPane.rowIndex="2" />

                        <Label text="國曆生日" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <TextField fx:id="birthSunField" promptText="YYY.MM.DD" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="農曆生日" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                        <TextField fx:id="birthMoonField" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                        <HBox alignment="CENTER_LEFT" spacing="5" GridPane.columnIndex="0" GridPane.columnSpan="6" GridPane.rowIndex="4">
                            <Label text="年齡" /> <TextField fx:id="ageField" prefWidth="40" />
                            <Label text="生肖" /> <TextField fx:id="zodiacField" prefWidth="40" />
                            <Label text="歲次" /> <TextField fx:id="yearCycleField" prefWidth="60" />
                            <Label text="時辰" /> <ComboBox fx:id="hourBox" prefWidth="70" />
                            <CheckBox text="是否郵寄" selected="true" />
                        </HBox>

                        <Label text="備註" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <TextField fx:id="memberNoteField" GridPane.columnIndex="1" GridPane.columnSpan="5" GridPane.rowIndex="5" />
                    </GridPane>
                </TitledPane>

<!--                <TableView fx:id="memberTable" VBox.vgrow="ALWAYS">-->
<!--                    <columns>-->
<!--                        <TableColumn text="電腦編號" prefWidth="80" />-->
<!--                        <TableColumn text="姓名" prefWidth="80" />-->
<!--                        <TableColumn text="郵寄" prefWidth="40" />-->
<!--                        <TableColumn text="國曆生日" prefWidth="100" />-->
<!--                        <TableColumn text="農曆生日" prefWidth="100" />-->
<!--                        <TableColumn text="年齡" prefWidth="40" />-->
<!--                        <TableColumn text="生肖" prefWidth="50" />-->
<!--                        <TableColumn text="歲次" prefWidth="60" />-->
<!--                        <TableColumn text="時辰" prefWidth="60" />-->
<!--                        <TableColumn text="性別" prefWidth="50" />-->
<!--                    </columns>-->
<!--                </TableView>-->
            </VBox>

            <VBox prefWidth="300" spacing="5" style="-fx-background-color: #ffe4e1; -fx-border-color: #cd5c5c;">
                <padding><Insets/></padding>
                <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="捐款作業 / 點燈項目" />

                <GridPane hgap="5" vgap="8">
                    <Label text="款項類別" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <ComboBox prefWidth="180" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                    <Label text="收據編號" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <TextField GridPane.rowIndex="1" GridPane.columnIndex="1" />

                    <Label text="捐款日期" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                    <DatePicker prefWidth="180" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                    <Label text="金額" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                    <TextField style="-fx-text-fill: red; -fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                    <Label text="摘要" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                    <TextField GridPane.rowIndex="4" GridPane.columnIndex="1" />
                </GridPane>

                <TextArea fx:id="donateNote" prefHeight="100" promptText="捐款備註/其他註記" />

                <VBox spacing="5" style="-fx-padding: 10 0 0 0;">
                    <Button maxWidth="Infinity" text="新增項目" />
                    <Button maxWidth="Infinity" text="修改項目" />
                    <Button maxWidth="Infinity" text="刪除項目" />
                    <Button maxWidth="Infinity" text="補據" />
                </VBox>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox spacing="10" style="-fx-background-color: #e0e0e0; -fx-padding: 5;">
            <Label text="就緒" />
            <Separator orientation="VERTICAL" />
            <Label fx:id="printerStatusLabel" text="預設印表機: Brother DCP-L2540DW series" />
        </HBox>
    </bottom>
</BorderPane>